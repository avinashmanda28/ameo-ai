# ═══════════════════════════════════════════════════════════════
# AMEO AI — Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Database ───────────────────────────────────────────────
# PostgreSQL via Supabase connection pooling (transaction mode)
# Replace PROJECT_REF, PASSWORD with your Supabase project details
# URL-encode special characters in password: @ → %40, $ → %24, * → %2A, [ → %5B, ] → %5D
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct session-mode pooler connection (used for Prisma migrations)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ─── AI Provider API Keys ──────────────────────────────────
# Configure at least one provider for runtime execution

# OpenRouter (https://openrouter.ai)
# OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# Groq (https://console.groq.com)
# GROQ_API_KEY="gsk_your-key-here"

# Google Gemini (https://ai.google.dev)
# GEMINI_API_KEY="AIza-your-key-here"

# Ollama (local, no key needed)
# OLLAMA_BASE_URL="http://localhost:11434"

# ─── Application ───────────────────────────────────────────
NODE_ENV="development"
