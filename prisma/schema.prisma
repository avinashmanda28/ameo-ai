// ═══════════════════════════════════════════════════════════════
// PHASE 15 — AGI LEARNING & FEEDBACK LOOP (System 9)
// ═══════════════════════════════════════════════════════════════

// ─── LEARNING RECORD — Execution outcome tracking ───

model LearningRecord {
  id            String   @id @default(cuid())
  workspaceId   String

  // What was executed
  executionId   String?
  workflowId    String?
  agentId       String?
  actionType    String   // execution | recommendation | workflow | automation | decision
  actionId      String   // ID of the action

  // Outcome
  outcome       String   // success | failure | partial | unknown
  outcomeScore  Float?   // 0-1 success score
  durationMs    Int?
  errorType     String?
  errorMessage  String?

  // Context
  context       String?  @db.Text // JSON — full context snapshot
  inputData     String?  @db.Text // JSON — input data
  outputData    String?  @db.Text // JSON — output/result

  // Learning signals
  signals       String?  // JSON — extracted signals
  lessons       String?  @db.Text // JSON — learned lessons
  patterns      String?  // JSON — detected patterns

  // Feedback integration
  feedbackId    String?  // link to feedback
  applied       Boolean  @default(false)
  appliedAt     DateTime?

  // Status
  status        String   @default("recorded") // recorded | analyzed | applied | archived

  metadata      String?  // JSON

  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── FEEDBACK RECORD — Explicit feedback on recommendations/actions ───

model FeedbackRecord {
  id            String   @id @default(cuid())
  workspaceId   String

  // Source
  sourceType    String   // recommendation | execution | workflow | automation | content
  sourceId      String

  // Feedback
  rating        Int?     // 1-5
  category      String?  // helpful | accurate | relevant | timely | custom
  sentiment     String?  // positive | neutral | negative
  comment       String?  @db.Text

  // Behavioral signals
  applied       Boolean  @default(false)
  dwellTimeMs   Int?     // time spent reviewing
  clicked       Boolean  @default(false)
  shared        Boolean  @default(false)

  // Agent improvement
  improvementAreas String? // JSON — areas for improvement
  confidenceDelta  Float?  // change in confidence after feedback

  metadata      String?  // JSON

  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── LEARNING ADAPTATION — Operational improvements from learning ───

model LearningAdaptation {
  id            String   @id @default(cuid())
  workspaceId   String

  // Adaptation identity
  name          String
  description   String?  @db.Text
  type          String   // workflow_optimization | prompt_tuning | routing_change | threshold_adjustment | automation_change | agent_behavior

  // Source learning
  sourceRecordId String? // link to LearningRecord
  sourceFeedbackId String? // link to FeedbackRecord

  // Change details
  previousConfig String? @db.Text // JSON — before
  newConfig      String? @db.Text // JSON — after
  changeRationale String? @db.Text

  // Impact
  impactScore    Float?   // measured improvement 0-1
  impactMetrics  String?  // JSON — quantitative impact
  rollbackCount  Int      @default(0)

  // Status
  status         String   @default("proposed") // proposed | tested | applied | reverted | archived
  appliedAt      DateTime?
  revertedAt     DateTime?

  // Governance
  requiresApproval Boolean @default(false)
  approvedBy      String?
  approvedAt      DateTime?

  metadata       String?  // JSON

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── TREND ACCURACY — Scoring trend prediction accuracy ───

model TrendAccuracy {
  id            String   @id @default(cuid())
  workspaceId   String
  trendId       String?

  // Prediction
  predictedDirection String // up | down | stable
  predictedMagnitude Float? // predicted change %
  predictedTimeframe String? // short_term | medium_term | long_term

  // Actual outcome
  actualDirection  String? // up | down | stable
  actualMagnitude  Float?  // actual change %

  // Accuracy
  accuracyScore    Float?  // 0-1 accuracy
  wasCorrect       Boolean?
  errorMargin      Float?  // absolute error

  // Source
  source           String? // ai_prediction | model | analyst
  signalId         String? // link to trend signal

  // Timing
  predictedAt      DateTime?
  actualAt         DateTime?

  metadata         String? // JSON

  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// PHASE 16 — GLOBAL OPERATIONAL COMMAND CLOUD (System 10)
// ═══════════════════════════════════════════════════════════════

// ─── RUNTIME NODE — Distributed runtime execution node ───

model RuntimeNode {
  id            String   @id @default(cuid())
  workspaceId   String
  clusterId     String?

  // Node identity
  name          String
  type          String   // primary | secondary | worker | edge
  region        String?  // us-east | eu-west | ap-southeast | etc.
  provider      String?  // aws | gcp | azure | self_hosted | edge

  // Connection
  endpoint      String?
  apiKey        String?
  apiVersion    String?

  // Capabilities
  capabilities  String?  // JSON — what this node can run
  maxConcurrency Int?    @default(10)
  currentLoad   Int?     @default(0)

  // Health
  status        String   @default("offline") // online | offline | degraded | draining | maintenance
  healthScore   Float?   @default(0)
  lastHeartbeat DateTime?
  lastHealthCheckAt DateTime?

  // Performance
  averageLatencyMs Int? @default(0)
  errorRate     Float?  @default(0)
  executionCount Int    @default(0)
  failoverCount Int     @default(0)

  // Config
  config        String?  // JSON — node-specific config
  metadata      String?  // JSON

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cluster   RuntimeCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
}

// ─── RUNTIME CLUSTER — Group of runtime nodes ───

model RuntimeCluster {
  id            String   @id @default(cuid())
  workspaceId   String

  // Cluster identity
  name          String
  description   String?
  type          String   // kubernetes | docker_swarm | nomad | custom

  // Configuration
  config        String?  // JSON — cluster config
  strategy      String   @default("round_robin") // round_robin | least_load | priority | failover | custom

  // Health
  status        String   @default("active") // active | degraded | offline
  healthScore   Float?   @default(0)
  totalNodes    Int      @default(0)
  activeNodes   Int      @default(0)

  // Metrics
  totalExecutions Int    @default(0)
  failedExecutions Int   @default(0)
  averageLatencyMs Int?  @default(0)

  // Auto-scaling
  autoScaling   Boolean  @default(false)
  minNodes      Int?     @default(1)
  maxNodes      Int?     @default(10)
  targetCpuUtilization Float? // 0-1 target CPU

  metadata      String?  // JSON

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nodes     RuntimeNode[]
}

// ─── EXECUTION ROUTE — Multi-provider execution routing rules ───

model ExecutionRoute {
  id            String   @id @default(cuid())
  workspaceId   String

  // Route identity
  name          String
  description   String?
  type          String   // primary | fallback | load_balanced | priority | conditional

  // Source
  sourceType    String?  // request_type | agent_type | workflow | model | latency
  sourceValue   String?  // value to match

  // Target (where to route)
  targetType    String   // provider | node | cluster | custom
  targetId      String

  // Priority
  priority      Int      @default(0)
  weight        Int?     @default(1) // for load balancing

  // Conditions
  conditions    String?  // JSON — routing conditions
  fallbackRouteId String? // when this route fails

  // Config
  config        String?  // JSON

  // Status
  enabled       Boolean  @default(true)
  status        String   @default("active") // active | paused | error

  // Metrics
  executionCount Int     @default(0)
  successCount  Int      @default(0)
  failoverCount Int      @default(0)
  averageLatencyMs Int?  @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── FAILOVER CONFIG — Operational failover configuration ───

model FailoverConfig {
  id            String   @id @default(cuid())
  workspaceId   String

  // Config identity
  name          String
  description   String?
  type          String   // provider | node | cluster | region | global

  // Primary & backup
  primaryId     String   // ID of primary resource
  backupIds     String?  // JSON array of backup resource IDs
  currentActive String   // currently active resource ID

  // Triggers
  failoverTriggers String? // JSON — what triggers a failover
  healthThreshold  Float?  @default(50) // health score threshold
  latencyThreshold Int?    @default(30000) // ms
  errorRateThreshold Float? @default(0.2) // 20%

  // Behavior
  autoFailover  Boolean  @default(true)
  autoRecovery  Boolean  @default(true)
  cooldownMs    Int?     @default(300000) // 5 min before auto-recovery

  // History
  failoverCount Int      @default(0)
  lastFailoverAt DateTime?
  lastRecoveryAt DateTime?

  // Status
  enabled       Boolean  @default(true)
  status        String   @default("active") // active | failing_over | recovering | paused

  config        String?  // JSON — additional config

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── COORDINATION COMMAND — AGI coordination commands ───

model CoordinationCommand {
  id            String   @id @default(cuid())
  workspaceId   String

  // Command identity
  command       String   // scale_up | scale_down | failover | recover | route_update | rebalance | maintenance
  source        String   // auto_scaler | health_monitor | operator | scheduler | agi_coordinator

  // Target
  targetType    String   // node | cluster | provider | region | global
  targetId      String?

  // Command data
  params        String?  @db.Text // JSON — command parameters
  priority      Int      @default(0)

  // Status
  status        String   @default("issued") // issued | acknowledged | executing | completed | failed | cancelled

  // Execution
  executedBy    String?  // system | agent | user
  startedAt     DateTime?
  completedAt   DateTime?
  result        String?  @db.Text // JSON — execution result
  error         String?  @db.Text

  // Coordination
  correlationId String?
  traceId       String?

  metadata      String?  // JSON

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
