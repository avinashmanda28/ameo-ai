generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// WORKSPACE — Top-level operational container
// ═══════════════════════════════════════════════════════════════

model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  mode        String   @default("builder") // builder | operations | strategy | governance
  status      String   @default("active")  // active | archived | suspended
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies       Company[]
  workflows       Workflow[]
  agents          Agent[]
  runtimes        RuntimeProvider[]
  governanceRules GovernanceRule[]
  auditLogs       AuditLog[]
  buildRatings    BuildRating[]
  artifacts       Artifact[]
  executions      RuntimeExecution[]
  approvalRequests ApprovalRequest[]
}

// ═══════════════════════════════════════════════════════════════
// COMPANY GRAPH — Entity hierarchy
// ═══════════════════════════════════════════════════════════════

model Company {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        String
  parentId    String?
  metadata    String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Company?  @relation("CompanyTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Company[] @relation("CompanyTree")
}

// ═══════════════════════════════════════════════════════════════
// RUNTIME HUB — AI provider abstraction
// ═══════════════════════════════════════════════════════════════

model RuntimeProvider {
  id             String  @id @default(cuid())
  workspaceId    String
  name           String
  type           String  // openrouter | groq | gemini | ollama
  apiKey         String?
  baseUrl        String?
  modelId        String?
  status         String  @default("inactive")
  role           String? // primary | secondary | fallback
  healthScore    Float   @default(0)
  rating         Float   @default(0)
  lastHealthCheck DateTime?
  config         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace  Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  healthLogs RuntimeHealthLog[]
  executions RuntimeExecution[]
}

model RuntimeHealthLog {
  id           String   @id @default(cuid())
  providerId   String
  status       String
  latencyMs    Int?
  errorMessage String?
  createdAt    DateTime @default(now())

  provider RuntimeProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// WORKFLOW ENGINE — State machine with full lifecycle
// ═══════════════════════════════════════════════════════════════

model Workflow {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  type        String?
  state       String   @default("draft")
  definition  String?
  config      String?
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions   WorkflowExecution[]
  checkpoints  WorkflowCheckpoint[]
  logs         WorkflowLog[]
  depSources   WorkflowDependency[]  @relation("WorkflowDepSource")
  depTargets   WorkflowDependency[]  @relation("WorkflowDepTarget")
}

model WorkflowExecution {
  id          String    @id @default(cuid())
  workflowId  String
  agentId     String?
  status      String    @default("pending")
  stepName    String?
  input       String?
  output      String?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  agent    Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
}

model WorkflowCheckpoint {
  id          String   @id @default(cuid())
  workflowId  String
  executionId String?
  name        String
  state       String
  data        String?
  createdAt   DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model WorkflowLog {
  id          String   @id @default(cuid())
  workflowId  String
  executionId String?
  level       String   @default("info")
  message     String
  metadata    String?
  createdAt   DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model WorkflowDependency {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  type      String   @default("after")
  createdAt DateTime @default(now())

  source Workflow @relation("WorkflowDepSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Workflow @relation("WorkflowDepTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// GOVERNANCE KERNEL
// ═══════════════════════════════════════════════════════════════

model GovernanceRule {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        String
  description String?
  config      String?
  enabled     Boolean  @default(true)
  severity    String   @default("medium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  ruleId      String?
  agentId     String?
  action      String
  resource    String?
  severity    String   @default("info")
  details     String?
  approved    Boolean?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// AGENT SYSTEM
// ═══════════════════════════════════════════════════════════════

model Agent {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  type         String
  description  String?
  status       String   @default("idle")
  config       String?
  capabilities String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]
  logs       AgentLog[]
  runtimeExecutions RuntimeExecution[]
}

model AgentLog {
  id        String   @id @default(cuid())
  agentId   String
  level     String   @default("info")
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// BUILD RATING ENGINE
// ═══════════════════════════════════════════════════════════════

model BuildRating {
  id                     String   @id @default(cuid())
  workspaceId            String
  targetId               String
  targetType             String
  architectureQuality    Float?
  runtimeStability       Float?
  uiIntegrity            Float?
  workflowQuality        Float?
  verificationConfidence Float?
  hallucinationRisk      Float?
  operationalStability   Float?
  overallScore           Float?
  notes                  String?
  createdAt              DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════
// PHASE 1.5 — RUNTIME EXECUTION LAYER
// ═══════════════════════════════════════════════════════════════

// Runtime Execution — actual AI calls with full audit trail
model RuntimeExecution {
  id              String    @id @default(cuid())
  workspaceId     String
  providerId      String?
  agentId         String?
  workflowId      String?
  artifactId      String?

  // Request data
  requestType     String    // chat | completion | embedding
  prompt          String
  systemPrompt    String?
  modelId         String?
  temperature     Float?
  maxTokens       Int?

  // Response data
  status          String    @default("pending") // pending | awaiting_approval | approved | rejected | executing | completed | failed | timed_out
  response        String?
  errorMessage    String?
  tokenUsage      String?   // JSON { promptTokens, completionTokens, totalTokens }
  latencyMs       Int?

  // Approval
  approvalId      String?   // links to ApprovalRequest
  approvedAt      DateTime?
  approvedBy      String?   // user or agent who approved

  // Verification
  verificationResult  String? // pass | fail | warning
  verificationNotes   String?
  hallucinationDetected Boolean @default(false)
  verificationAgentId String?

  // Metrics
  qualityScore    Float?
  retryCount      Int       @default(0)
  timedOut        Boolean   @default(false)

  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  provider     RuntimeProvider?  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  agent        Agent?            @relation(fields: [agentId], references: [id], onDelete: SetNull)
  artifact     Artifact?         @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  approval     ApprovalRequest?  @relation(fields: [approvalId], references: [id], onDelete: SetNull)
}

// Artifact — persistent outputs from execution
model Artifact {
  id            String   @id @default(cuid())
  workspaceId   String
  executionId   String?  // link to runtime execution that produced this
  workflowId    String?
  agentId       String?

  title         String
  type          String   // code | report | plan | spec | analysis | architecture | general
  language      String?  // for code artifacts
  content       String   // the actual artifact content
  summary       String?  // brief description
  metadata      String?  // JSON

  status        String   @default("draft") // draft | verified | approved | rejected | archived
  version       Int      @default(1)

  verificationResult  String? // pass | fail | warning
  verificationNotes   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions        RuntimeExecution[]
}

// Approval Request — governance gate for runtime operations
model ApprovalRequest {
  id            String   @id @default(cuid())
  workspaceId   String
  executionId   String?  // link to runtime execution awaiting approval

  requestType   String   // runtime_execution | deployment | data_export | sensitive_action
  providerName  String?
  providerType  String?

  // What will be sent
  promptPreview String?  // first N chars of the prompt
  dataSize      Int?     // estimated data size
  metadata      String?  // JSON with additional context

  // Resolution
  status        String   @default("pending") // pending | approved | rejected | expired
  resolvedAt    DateTime?
  resolvedBy    String?  // "user" or agent name

  // Expiry
  expiresAt     DateTime?

  reason        String?  // rejection reason if rejected

  createdAt     DateTime @default(now())

  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions     RuntimeExecution[]
}
